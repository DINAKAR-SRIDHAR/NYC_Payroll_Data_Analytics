{
	"name": "dataflow_agency",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_AGENCY",
						"type": "DatasetReference"
					},
					"name": "SRCAGENCY"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_AGENCY_MD",
						"type": "DatasetReference"
					},
					"name": "MDAGENCY"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          AgencyID as integer,",
				"          AgencyName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SRCAGENCY",
				"SRCAGENCY sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AgencyID as string,",
				"          AgencyName as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          AgencyID,",
				"          AgencyName",
				"     )) ~> MDAGENCY"
			]
		}
	}
}