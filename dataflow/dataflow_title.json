{
	"name": "dataflow_title",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_TITLE",
						"type": "DatasetReference"
					},
					"name": "SRCTITLE"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_TITLE_MD",
						"type": "DatasetReference"
					},
					"name": "MDTITLE"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          TitleCode as integer,",
				"          TitleDescription as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SRCTITLE",
				"SRCTITLE sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          TitleCode as string,",
				"          TitleDescription as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          TitleCode,",
				"          TitleDescription",
				"     )) ~> MDTITLE"
			]
		}
	}
}